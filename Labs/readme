.venv\Scripts\activate
west build -p always -b rpi_pico2/rp2350a/m33 -S cdc-acm-console


# prj.conf
# 串口与控制台配置
CONFIG_SERIAL=y
CONFIG_CONSOLE=y
CONFIG_UART_CONSOLE=y

# 启用 CDC ACM 驱动
CONFIG_UART_LINE_CTRL=y
CONFIG_USB_CDC_ACM=y

# 启动时自动初始化 (注意: 参数名通常如下)
CONFIG_USB_DEVICE_INITIALIZE_AT_BOOT=y

# 调试优化
CONFIG_DEBUG=y
